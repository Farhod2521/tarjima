# Backend environment variables

# Required
OPENAI_API_KEY=sk-your-key-here

# Balanced quality/cost for Uzbek spelling and translation.
# For maximum accuracy, use: gpt-5.4
# For cheaper high-volume checks, use: gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=60

# Uploads and chunking
MAX_FILE_SIZE_MB=200
CHUNK_SIZE_CHARS=3000
MAX_PARALLEL_CHUNKS=4
MAX_PARALLEL_TRANSLATIONS=4

# CORS
ALLOWED_ORIGINS=*
